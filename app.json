{
  "expo": {
    "name": "Usetri",
    "slug": "usetri",
    "version": "1.0.19",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "usetri",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "googleServicesFile": "./GoogleService-Info.plist",
      "bundleIdentifier": "com.dutosvarc.usetri",
      "infoPlist": {
        "NSCameraUsageDescription": "This app uses your camera to scan product barcodes and help you track your purchases"
      },
      "config": {
        "usesNonExemptEncryption": false
      },
      "usesAppleSignIn": true
    },
    "android": {
      "versionCode": 8,
      "googleServicesFile": "./google-services.json",
      "package": "com.dutosvarc.usetri",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#5645CC"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/crashlytics",
      "@react-native-google-signin/google-signin",
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "newArchEnabled": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "Allow $(PRODUCT_NAME) to access your Face ID biometric data."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Usetri needs access to your photos so you can save a picture of your loyalty card.",
          "cameraPermission": "Usetri needs access to your camera to take a picture of your loyalty card."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "This app uses your camera to scan product barcodes and help you track your purchases",
          "enableCodeScanner": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "ios": {
            "image": "./assets/splash.png",
            "imageContentMode": "cover",
            "backgroundColor": "#ffffff",
            "enableFullScreenImage_legacy": true
          },
          "android": {
            "image": "./assets/images/usetri-logo_base-purple.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/OTF/Expose-Regular.otf",
            "./assets/fonts/OTF/Expose-Medium.otf",
            "./assets/fonts/OTF/Expose-Bold.otf",
            "./assets/fonts/OTF/Expose-Black.otf"
          ]
        }
      ],
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "791d2b8e-8cce-4c33-9378-6898f9ab1df7"
      }
    },
    "owner": "adammartiska"
  }
}
